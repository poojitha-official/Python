def maxSubarraySum(arr, n) :
    max_sum=arr[0]
    current_sum=arr[0]
    for i in range(1,n):
        current_sum=max(arr[i],arr[i]+current_sum)
        max_sum=max(max_sum,current_sum)
    return max(0,max_sum)
