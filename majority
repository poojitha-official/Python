class Solution:
    def majorityElement(self, nums: List[int]) -> int:
        n=len(nums)
        d={}
        lst=[]
        for i in nums:
            if i in d:
                d[i]=d[i]+1
            else:
                d[i]=1
        for i,j in d.items():
            if(j>n//2):
                lst.append(i)
        result = ''
        for num in lst:
             result += str(num)
        return int(result)


        
