class Solution:
    def majorityElement(self, nums: List[int]) -> List[int]:
        n=len(nums)
        lst=[]
        d={}
        for i in nums:
            if i in d:
                d[i]=d[i]+1
            else:
                d[i]=1
        for i,j in d.items():
            if(j>n//3):
                lst.append(i)
        return lst
